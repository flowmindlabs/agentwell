# Copy this to .env for local development only.
# NEVER commit .env — use system environment variables in production.

AGENTWELL_UPSTREAM=http://localhost:3030
AGENTWELL_PORT=3001
AGENTWELL_API_KEY=
AGENTWELL_HEALTH_THRESHOLD=70
AGENTWELL_WINDOW_SIZE=20
AGENTWELL_DB_PATH=./agentwell.db
AGENTWELL_STORE_EMBEDDINGS=false
